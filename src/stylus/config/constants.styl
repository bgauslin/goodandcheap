@import 'functions'

BRAND_COLOR = #e5001f

LINK_COLOR = #1565c0
LINK_VISITED = mix(LINK_COLOR, white, 50%)

PAGE_MAX_WIDTH = rem(800)
PAGE_WIDTH_STACKED = rem(560)

// Webfont icons.
icon-angle-left = '\e802'
icon-angle-right = '\e803' // not used
icon-cancel = '\e809' // not used
icon-cancel-circled = '\e808'
icon-circle-empty = '\e806'
icon-heart = '\e80a'
icon-heart-empty = '\e80b'
icon-left-open = '\e800' // not used
icon-ok-circled = '\e807'
icon-right-open = '\e801'
icon-search = '\e804'
icon-user = '\e805'  // not used

// @type Hash
BreakpointUnits = {
  SMALL: rem(480)
  MEDIUM: rem(768)
  LARGE: rem(1024)
  XLARGE: rem(1280)
}

// @type Hash
Margin = {
  BASE: rem(12)
  SMALL: rem(24)
  MEDIUM: rem(36)
  LARGE: rem(48)
}

// @type Hash
// @require BreakpointUnits
Breakpoint = {
  SMALL: 'screen and (min-width: %s)' % BreakpointUnits.SMALL
  MEDIUM: 'screen and (min-width: %s)' % BreakpointUnits.MEDIUM
  LARGE: 'screen and (min-width: %s)' % BreakpointUnits.LARGE
  XLARGE: 'screen and (min-width: %s)' % BreakpointUnits.XLARGE
  SEARCH_ENABLED: 'screen and (max-width: %s)' % BreakpointUnits.MEDIUM
}

// @type Hash
// @require BreakpointUnits
// @require Margin
ContentWidth = {
  SMALL: BreakpointUnits.SMALL - (2 * Margin.SMALL)
  MEDIUM: BreakpointUnits.MEDIUM - (2 * Margin.MEDIUM)
  XLARGE: BreakpointUnits.XLARGE - (2 * Margin.LARGE)
}
