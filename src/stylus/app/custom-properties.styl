:root
  // Layout
  --header-height rem(48)
  --margin margin-base

  @media breakpoint.small
    --margin margin-small

  @media breakpoint.medium
    --columns 2
    --header-height rem(56)
    --margin margin-medium

  @media breakpoint.large
    --columns 3
    --margin margin-large

  // Default light mode.
  --dark-grey #333
  --light-grey #aaa
  --lighter-grey #eee
  --medium-grey #777
  --off-white #f2f2f2

  --border-color #eee
  --badge-color #ffc500
  --brand-color brand-color

  --link-color link-color
  --link-color-visited link-color-visited
