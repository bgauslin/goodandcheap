// ----------------------------------------
// .previews grids

previews-grid()
  display flex
  flex-direction row
  flex-wrap wrap

preview-grid()
  margin -1px 0 0 -1px
  border 1px solid border-color
  width calc(50% + 1px)

preview-grid-large()
  width calc((1/3 * 100%) + 1px)

// ----------------------------------------
// .preview

preview()
  position relative
  list-style none

  a
    display flex
    flex-direction row
    align-items center
    background white
    border-top 1px solid border-color
    link(dark-grey, medium-grey, brand-color)

  h3
    serif-heavy()
    line-height 1.1

  .summary
    flex-grow 1
    margin-left .5rem

  &:last-child
    a
      border-bottom 1px solid border-color

preview-no-touch()
  a
    link-hover(brand-color)

// ----------------------------------------
// .cover

cover()
  background white

  img
    animation fadeIn .5s ease-out

  h1
    serif-heavy()
    margin-bottom .5em

    @media(min-width breakpoint-large)
      font-size em(30)

  .blurb
    padding 1rem
    animation slideInUp .3s ease-out

    & > div
      serif()

cover-small()
  aspect-ratio(1, 1)
  overflow hidden

  .blurb
    position-it(absolute, 0, 3rem, null, 3rem)
    padding 1.5rem
    box-shadow 0 0 5px 0 light-grey // horiz vert blur spread color
    background rgba(white, 0.95)
    animation slideInDown .3s ease-out
