// margins
MARGINS_BASE = px_to_rem(12)
MARGINS_SMALL = px_to_rem(24)
MARGINS_MEDIUM = px_to_rem(36)
MARGINS_LARGE = px_to_rem(48)

// breakpoints
BREAKPOINT_SMALL = px_to_rem(480)
BREAKPOINT_MEDIUM = px_to_rem(768)
BREAKPOINT_LARGE = px_to_rem(1024)
BREAKPOINT_XLARGE = px_to_rem(1280)

// content widths
WIDTH_SMALL = BREAKPOINT_SMALL - (2 * MARGINS_SMALL)
WIDTH_MEDIUM = BREAKPOINT_MEDIUM - (2 * MARGINS_MEDIUM)
WIDTH_LARGE = BREAKPOINT_LARGE - (2 * MARGINS_LARGE)
WIDTH_XLARGE = BREAKPOINT_XLARGE - (2 * MARGINS_LARGE)

// header heights
HEADER_HEIGHT_BASE = px_to_rem(44)
HEADER_HEIGHT_MEDIUM = px_to_rem(56)

// stacked width (for medium layouts)
STACKED_WIDTH = px_to_rem(560)

// page max width
PAGE_MAX_WIDTH = px_to_rem(800)
