webfont('CarminaBT-Bold', '/ui/webfonts/CarminaBT-Bold/CarminaBT-Bold')
webfont('CarminaBT-Light', '/ui/webfonts/CarminaBT-Light/CarminaBT-Light')
webfont('Futura-Book', '/ui/webfonts/Futura-Book/Futura-Book')
webfont('Futura-Bold', '/ui/webfonts/Futura-Bold/Futura-Bold')
webfont('Icons', '/ui/webfonts/icons/icons')

body
  background var(--color-off-white)
  color var(--color-grey-dark)
  margin 0
  padding 0

*
  box-sizing border-box
  text-size-adjust none
  -webkit-tap-highlight-color transparent

figure
  margin 0
  padding 0

img
  height auto
  vertical-align middle
  width 100%

h1
h2
h3
p
ul
ol
  margin 0
  padding 0

h1
h2
h3
  line-height 1.1

h1
  font-size var(--h1)

h2
  font-size var(--h2)
  margin 1em 0

h3
  font-size var(--h3)

p
  line-height 1.5

b
strong
  font-weight normal

a
  background transparent
  link(var(--link), var(--link-visited), var(--color-grey-dark))
  text-decoration none

.no-touch a
  link_hover(var(--color-grey-dark))
  transition background .3s ease, border .3s ease, color .3s ease

button
  background transparent
  border none
  color inherit
  cursor pointer
  font inherit
  margin 0
  outline none
  overflow visible
  text-transform none

a:focus
button:focus
  outline none
